## 🐳 5. Docker и Инфраструктура

### 5.1 Docker Compose (полная конфигурация)

```yaml
# docker-compose.yml
version: '3.8'

services:
  postgres:
    image: postgres:15-alpine
    container_name: vselena-db
    environment:
      POSTGRES_DB: vselena_dev
      POSTGRES_USER: vselena
      POSTGRES_PASSWORD: vselena_secret
    ports:
      - '5432:5432'
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./backend/database/init.sql:/docker-entrypoint-initdb.d/init.sql
    networks:
      - vselena-network
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -U vselena']
      interval: 10s
      timeout: 5s
      retries: 5


  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
      target: development
    container_name: vselena-backend
    environment:
      NODE_ENV: development
      DB_HOST: postgres
      DB_PORT: 5432
      DB_USERNAME: vselena
      DB_PASSWORD: vselena_secret
      DB_DATABASE: vselena_dev
      JWT_SECRET: your-super-secret-jwt-key-change-in-production-min-32-chars
      JWT_REFRESH_SECRET: your-refresh-secret-key-min-32-chars
      JWT_EXPIRATION: 15m
      JWT_REFRESH_EXPIRATION: 7d
      FRONTEND_URL: http://localhost:3000
    ports:
      - '3001:3001'
    volumes:
      - ./backend:/app
      - /app/node_modules
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - vselena-network
    command: npm run start:dev
    restart: unless-stopped

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
      target: development
    container_name: vselena-frontend
    environment:
      NEXT_PUBLIC_API_URL: http://localhost:3001/api
    ports:
      - '3000:3000'
    volumes:
      - ./frontend:/app
      - /app/node_modules
      - /app/.next
    depends_on:
      - backend
    networks:
      - vselena-network
    command: npm run dev
    restart: unless-stopped

  # Adminer для управления БД (опционально)
  adminer:
    image: adminer:latest
    container_name: vselena-adminer
    ports:
      - '8080:8080'
    networks:
      - vselena-network
    depends_on:
      - postgres
    environment:
      ADMINER_DEFAULT_SERVER: postgres

volumes:
  postgres_data:

networks:
  vselena-network:
    driver: bridge
```

### 5.2 Backend Dockerfile (multi-stage)

```dockerfile
# backend/Dockerfile

# ========================================
# Stage 1: Base
# ========================================
FROM node:18-alpine AS base
WORKDIR /app
COPY package*.json ./

# ========================================
# Stage 2: Development
# ========================================
FROM base AS development
ENV NODE_ENV=development
RUN npm install
COPY . .
EXPOSE 3001
CMD ["npm", "run", "start:dev"]

# ========================================
# Stage 3: Build
# ========================================
FROM base AS build
RUN npm ci --only=production
COPY . .
RUN npm run build
RUN npm prune --production

# ========================================
# Stage 4: Production
# ========================================
FROM node:18-alpine AS production
WORKDIR /app

# Создаём non-root пользователя
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nestjs -u 1001

# Копируем dependencies
COPY --from=build --chown=nestjs:nodejs /app/node_modules ./node_modules
COPY --from=build --chown=nestjs:nodejs /app/dist ./dist
COPY --from=build --chown=nestjs:nodejs /app/package.json ./

USER nestjs

EXPOSE 3001

CMD ["node", "dist/main.js"]
```

